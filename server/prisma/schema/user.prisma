model User {
    id           String   @id @default(uuid())
    firstName    String
    lastName     String
    email        String   @unique
    password     String
    avatar       String?
    tokenVersion Int      @default(0)
    createdAt    DateTime @default(now())
    updatedAt    DateTime @updatedAt

    posts        Post[]
    comments     Comment[]
    replies      Reply[]
    likes        Like[]
    commentLikes CommentLike[]
    replyLikes   ReplyLike[]

    @@map("users")
}
