model ReplyLike {
    replyId   String
    userId    String
    createdAt DateTime @default(now())

    reply Reply @relation(fields: [replyId], references: [id], onDelete: Cascade)
    user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([replyId, userId])
    @@map("reply_likes")
}
