model Post {
    id        String   @id @default(uuid())
    text      String?
    imageUrl  String?
    isPrivate Boolean  @default(false)
    authorId  String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    author   User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
    comments Comment[]
    likes    Like[]

    @@index([authorId])
    @@map("posts")
}
