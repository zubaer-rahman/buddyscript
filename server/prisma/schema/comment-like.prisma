model CommentLike {
    commentId String
    userId    String
    createdAt DateTime @default(now())

    comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
    user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([commentId, userId])
    @@map("comment_likes")
}
